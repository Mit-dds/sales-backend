<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<style>
  @page { margin: 0; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Outfit', 'Segoe UI', Arial, sans-serif; -webkit-print-color-adjust: exact; print-color-adjust: exact; background: #f5efe7; color: #1f2430; }
  .op { page-break-after: always; break-after: page; overflow: hidden; position: relative; background: linear-gradient(180deg,#fcfaf7 0%,#f7efe6 100%); }
  .op:last-child { page-break-after: auto; break-after: auto; }
  .mono { font-family: 'Courier New', 'DM Mono', monospace; }
  .serif { font-family: 'Georgia', 'Cormorant Garamond', serif; }
  .soft-card { border: 1px solid rgba(23,30,43,0.08); border-radius: 20px; background: #fff; box-shadow: 0 18px 42px rgba(24,29,41,0.08); }
</style>
</head>
<body>
<%
  var project = typeof project !== 'undefined' ? project : {};
  var settings = typeof settings !== 'undefined' ? settings : {};
  var clientName = typeof clientName !== 'undefined' ? clientName : 'Valued Client';
  var agentName = typeof agentName !== 'undefined' ? agentName : '';
  var offers = typeof offers !== 'undefined' ? offers : [];
  var pc = project.primaryColor || '#1A3C6B';
  var hr = hexRgb(pc);
%>

<% (offers || []).forEach(function(off, idx) { %>
<div class="op" style="position:relative;overflow:hidden;">
  <% if (watermark || (settings && settings.teamName)) { %>
  <div style="position:absolute;top:40%;left:0;right:0;text-align:center;opacity:0.04;font-size:36px;font-weight:700;color:#1A2340;font-family:Georgia,'Cormorant Garamond',serif;letter-spacing:6px;transform:rotate(-30deg);pointer-events:none;z-index:0;">
    <%= watermark || settings.teamName || '' %>
  </div>
  <% } %>
  <div style="height:3px;background:linear-gradient(90deg,<%= pc %>,#A8C5E8);"></div>

  <div style="padding:20px 48px;display:flex;justify-content:space-between;align-items:flex-start;">
    <div>
      <div style="font-size:9px;color:#8892AA;letter-spacing:2px;font-family:'Courier New','DM Mono',monospace;margin-bottom:3px;">PLAN <%= idx + 1 %> <span style="color:#4A5880;letter-spacing:0.5px;text-transform:none;">for <%= clientName %></span></div>
      <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:18px;font-weight:600;color:#1A2340;"><%= off.plan.label %></div>
    </div>
    <div style="text-align:right;">
      <div style="font-size:10px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;letter-spacing:1px;"><%= fmtDate(offerDate || new Date()) %></div>
    </div>
  </div>

  <div style="padding:0 48px 24px;">
    <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:16px;">
      <div style="display:inline-flex;align-items:center;border-radius:4px;padding:4px 10px;font-size:10px;font-family:'Courier New','DM Mono',monospace;border:1px solid rgba(26,138,90,0.3);background:rgba(26,138,90,0.08);color:#1A8A5A;"><%= off.plan.discount %>% OFF</div>
      <div style="display:inline-flex;align-items:center;border-radius:4px;padding:4px 10px;font-size:10px;font-family:'Courier New','DM Mono',monospace;border:1px solid rgba(30,111,217,0.3);background:rgba(30,111,217,0.08);color:#1E6FD9;"><%= off.plan.dp %>% DP</div>
      <% if (off.plan.installmentPct > 0) { %>
      <div style="display:inline-flex;align-items:center;border-radius:4px;padding:4px 10px;font-size:10px;font-family:'Courier New','DM Mono',monospace;border:1px solid rgba(200,100,10,0.3);background:rgba(200,100,10,0.1);color:#C8640A;"><%= off.plan.installmentPct %>%/mo</div>
      <% } %>
    </div>

    <div style="font-size:9px;color:#8892AA;letter-spacing:2.5px;font-family:'Courier New','DM Mono',monospace;margin-bottom:12px;">INVESTMENT SUMMARY</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div class="soft-card" style="padding:16px;border-radius:14px;">
        <div style="font-size:10px;color:#8892AA;">NET PRICE</div>
        <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:<%= pc %>;"><%= fmtAED(off.netPrice) %></div>
        <div style="font-size:9px;color:#8892AA;margin-top:2px;">LIST: <%= fmtAED(off.netPrice / (1 - (off.plan.discount || 0) / 100)) %></div>
      </div>
      <div class="soft-card" style="padding:16px;border-radius:14px;background:linear-gradient(135deg,rgba(39,174,96,0.08),rgba(39,174,96,0.04));">
        <div style="font-size:10px;color:#8892AA;">YOUR SAVING</div>
        <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:#27AE60;"><%= fmtAED(off.discountAmt) %></div>
        <div style="font-size:9px;color:#8892AA;margin-top:2px;"><%= off.plan.discount %>% discount</div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:12px;">
      <div class="soft-card" style="padding:10px 14px;border-radius:10px;">
        <div style="font-size:9px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;">REG FEE</div>
        <div style="font-size:13px;font-weight:600;color:#1A2340;font-family:'Courier New','DM Mono',monospace;"><%= fmtAED(off.regFee) %></div>
      </div>
      <div style="padding:10px 14px;background:#F0F4FA;border-radius:6px;">
        <div style="font-size:9px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;">UTILITY</div>
        <div style="font-size:13px;font-weight:600;color:#1A2340;font-family:'Courier New','DM Mono',monospace;"><%= fmtAED(off.utility) %></div>
      </div>
      <% if (project.type !== 'Townhouses') { %>
      <div style="padding:10px 14px;background:#F0F4FA;border-radius:6px;">
        <div style="font-size:9px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;">PARKING</div>
        <div style="font-size:13px;font-weight:600;color:#1A2340;font-family:'Courier New','DM Mono',monospace;"><%= off.parking > 0 ? fmtAED(off.parking) : '-' %></div>
      </div>
      <% } %>
    </div>
  </div>

  <% if (off.schedule && off.schedule.length > 0) { %>
  <div style="padding:0 48px 32px;">
    <div style="font-size:9px;color:#8892AA;letter-spacing:2.5px;font-family:'Courier New','DM Mono',monospace;margin-bottom:12px;">SCHEDULE (<%= off.schedule.length %> payments)</div>
    <table style="width:100%;border-collapse:collapse;">
      <thead>
        <tr style="border-bottom:1px solid #D0DCF0;">
          <% ['#', 'Milestone', 'Amount'].forEach(function(h) { %>
          <th style="padding:8px 12px;text-align:left;font-size:10px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;letter-spacing:1px;"><%= h %></th>
          <% }); %>
        </tr>
      </thead>
      <tbody>
        <% off.schedule.forEach(function(r, i) { %>
        <tr style="border-bottom:1px solid #eee;">
          <td style="padding:8px 12px;font-size:11px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;"><%= i + 1 %></td>
          <td style="padding:8px 12px;font-size:12px;color:#1A2340;"><%= r.label %></td>
          <td style="padding:8px 12px;font-size:12px;font-weight:600;color:#1A2340;font-family:'Courier New','DM Mono',monospace;"><%= fmtAED(r.amount) %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>

  <div style="padding:16px 48px;border-top:1px solid #D0DCF0;display:flex;justify-content:space-between;align-items:center;">
    <div>
      <div style="font-size:9px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;letter-spacing:1px;">PREPARED FOR</div>
      <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:16px;font-weight:600;color:#1A2340;"><%= clientName %></div>
    </div>
    <div style="text-align:right;">
      <div style="font-size:12px;font-weight:600;color:#1A2340;"><%= agentName %></div>
      <div style="font-size:10px;color:#8892AA;"><%= settings.teamName || 'Reportage Properties' %></div>
    </div>
  </div>
</div>
<% }); %>
</body>
</html>
