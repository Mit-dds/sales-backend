              <% if (m.date) { %><div style="font-size:9px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;margin-top:1px;"><%= m.date %></div><% } %>
            </div>
            <div style="font-size:10px;font-weight:700;color:<%= dotColor %>;font-family:'Courier New','DM Mono',monospace;text-align:center;"><%= m.pct.toFixed(2) %>%</div>
            <div style="text-align:right;">
              <div style="font-size:<%= m.isHandover ? 12 : 11 %>px;font-weight:<%= m.isHandover ? 700 : 600 %>;color:<%= m.isHandover ? pc : '#1A2340' %>;font-family:'Courier New','DM Mono',monospace;"><%= fmtAED(m.amount) %></div>
              <div style="font-size:9px;color:#6A7890;font-family:'Courier New','DM Mono',monospace;margin-top:1px;"><%= fmtUSD(m.amount, usdRate) %></div>
              <% if (extraRate) { %><div style="font-size:9px;color:#6A7890;font-family:'Courier New','DM Mono',monospace;">(<%= extraCurrency %> <%= Math.round(m.amount * extraRate).toLocaleString('en-US') %>)</div><% } %>
