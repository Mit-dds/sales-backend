      <% if (agentPhone) { %><div style="font-size:10px;color:#8892AA;margin-top:1px;"><%= agentPhone %></div><% } %>
      <% if (agentEmail) { %><div style="font-size:10px;color:#8892AA;margin-top:1px;"><%= agentEmail %></div><% } %>
    </div>
  </div>
  <% } %>
</div>
<% }); %>

<%
