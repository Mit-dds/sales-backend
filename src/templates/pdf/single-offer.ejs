<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<style>
  @page { margin: 0; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    margin: 0;
    padding: 0;
    font-family: 'Outfit', 'Segoe UI', Arial, sans-serif;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
    background: #f5efe7;
    color: #1f2430;
  }
  .op {
    page-break-after: always;
    break-after: page;
    overflow: hidden;
    position: relative;
    width: 100%;
    min-height: 100vh;
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, #fcfaf7 0%, #f7efe6 100%);
  }
  .op:last-child { page-break-after: auto; break-after: auto; }
  .mono { font-family: 'Courier New', 'DM Mono', monospace; letter-spacing: 0.5px; }
  .serif { font-family: 'Georgia', 'Cormorant Garamond', serif; }
  .soft-card {
    border: 1px solid rgba(23, 30, 43, 0.08);
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 18px 42px rgba(24, 29, 41, 0.08);
  }
  .label {
    font-size: 9px;
    color: #8892AA;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    font-family: 'Courier New','DM Mono',monospace;
  }
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(123, 63, 26, 0.18), transparent);
  }
</style>
</head>
<body>
<%
  var project = typeof project !== 'undefined' ? project : {};
  var unit = typeof unit !== 'undefined' ? unit : {};
  var unitType = typeof unitType !== 'undefined' ? unitType : null;
  var plan = typeof plan !== 'undefined' ? plan : {};
  var settings = typeof settings !== 'undefined' ? settings : {};
  var clientName = typeof clientName !== 'undefined' ? clientName : 'Valued Client';
  var agentName = typeof agentName !== 'undefined' ? agentName : '';
  var agentPhone = typeof agentPhone !== 'undefined' ? agentPhone : '';
  var agentEmail = typeof agentEmail !== 'undefined' ? agentEmail : '';
  var netPrice = typeof netPrice !== 'undefined' ? netPrice : 0;
  var pc = project.primaryColor || '#7B3F1A';
  var sc = project.secondaryColor || '#D4A88A';
  var hr = hexRgb(pc);
  var usdRate = 1 / 3.65;
  var extraCurrency = typeof extraCurrency !== 'undefined' ? extraCurrency : '';
  var liveRates = typeof liveRates !== 'undefined' ? liveRates : null;
  var extraRate = extraCurrency && liveRates ? liveRates[extraCurrency] : null;
  var extraSym = extraCurrency || '';
  var discountAmt = typeof discountAmt !== 'undefined' ? discountAmt : 0;
  var regFee = typeof regFee !== 'undefined' ? regFee : 0;
  var utility = typeof utility !== 'undefined' ? utility : 0;
  var parking = typeof parking !== 'undefined' ? parking : 0;
  var fp = typeof fp !== 'undefined' ? fp : null;
  var eventName = typeof eventName !== 'undefined' ? eventName : '';
  var schedule = Array.isArray(schedule) ? schedule : [];
  var hasPark = parking > 0 && project.type !== 'Townhouses';
  var priceWithPark = netPrice + (hasPark ? parking : 0);
  var activeDiscount = plan.discount || 0;
  var hoMonths = getHandoverMonths(project.completionDate);

  var milestones = schedule.map(function(r) {
    return {
      label: r.label,
      date: r.date ? fmtDate(r.date) : '',
      amount: r.amount,
      pct: netPrice > 0 ? Math.round((r.amount / netPrice) * 10000) / 100 : 0,
      type: r.type,
      isHandover: r.type === 'handover',
      isBooking: r.type === 'booking'
    };
  });

  /* ---------------------------------------------------------------------
     PAGINATION FOR PAYMENT MILESTONES
     Page 2 already carries the Investment card + Why-Buy bar above the
     milestones list, so less vertical room is available there. Any extra
     milestones that don't fit are pushed onto additional "continued"
     pages that reuse the identical timeline styling. The footer is only
     ever drawn on the final milestones page, wherever that ends up.
     Tune msFirstPageCount / msPerContPage if row heights ever change.
  --------------------------------------------------------------------- */
  var msFirstPageCount = 9;   // milestones that fit on page 2 alongside the investment card
  var msPerContPage = 16;     // milestones that fit on a dedicated continuation page
  // Note: raise/lower these if the investment card grows a lot taller (e.g. saving
  // box + parking line + extra currency all present at once) and rows start
  // getting clipped again, or if pages are still ending with a lot of blank space.
  var msPages = [];
  if (milestones.length > 0) {
    if (milestones.length <= msFirstPageCount) {
      msPages.push(milestones);
    } else {
      msPages.push(milestones.slice(0, msFirstPageCount));
      var msRest = milestones.slice(msFirstPageCount);
      for (var msi = 0; msi < msRest.length; msi += msPerContPage) {
        msPages.push(msRest.slice(msi, msi + msPerContPage));
      }
    }
  }
  var msFirstChunk = msPages.length > 0 ? msPages[0] : [];
  var msContPages = msPages.slice(1);

  var hasInst = plan.installmentPct > 0;
  var instPct = 0;
  var hoPct2 = plan.onHandover || 0;
  if (hasInst) {
    if (plan.durationType === 'fixed_months' && plan.durationMonths) {
      instPct = Math.min(plan.installmentPct * plan.durationMonths, 100 - plan.dp);
      hoPct2 = Math.max(0, 100 - plan.dp - instPct);
    } else {
      var instMonths = Math.max(0, (hoMonths || 18) - 2);
      instPct = Math.min(plan.installmentPct * instMonths, 100 - plan.dp);
      hoPct2 = Math.max(0, Math.round((100 - plan.dp - instPct) * 10) / 10);
    }
  } else if (hoPct2 === 0) {
    hoPct2 = 100 - plan.dp;
  }

  var segs = hasInst && instPct > 0
    ? [{ label: 'Down Payment', pct: plan.dp, color: pc },
       { label: plan.installmentPct + '% Monthly', pct: Math.round(instPct), color: sc },
       { label: 'On Completion', pct: Math.round(hoPct2), color: '#8B6914' }]
    : [{ label: 'Down Payment', pct: plan.dp, color: pc },
       { label: 'On Completion', pct: Math.round(hoPct2), color: '#8B6914' }];
%>

<!-- Page 1: Cover + Investment -->
<div class="op" style="position:relative;overflow:hidden;display:flex;flex-direction:column;">
  <!-- Premium cover background -->
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;z-index:0;background:linear-gradient(135deg,#180f08 0%,#4a2d17 45%,#7b4318 100%);"></div>
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;z-index:0;background:radial-gradient(circle at top left, rgba(255,255,255,0.18), transparent 34%),radial-gradient(circle at bottom right, rgba(255,255,255,0.10), transparent 28%);"></div>
  <% if (watermark) { %>
  <div style="position:absolute;top:40%;left:0;right:0;text-align:center;opacity:0.04;font-size:48px;font-weight:700;color:#fff;font-family:Georgia,'Cormorant Garamond',serif;letter-spacing:8px;transform:rotate(-30deg);pointer-events:none;z-index:0;">
    <% if (watermark.startsWith('data:')) { %>
    <img src="<%= watermark %>" alt="" style="width:200px;opacity:0.3;margin:0 auto;" />
    <% } else { %>
    <%= watermark %>
    <% } %>
  </div>
  <% } %>

  <!-- Top: Prepared For + Date -->
  <div style="position:relative;z-index:1;padding:24px 48px 0;display:flex;justify-content:space-between;align-items:flex-start;">
    <div>
      <div style="font-size:9px;color:rgba(255,255,255,0.6);letter-spacing:3px;font-family:'Courier New','DM Mono',monospace;margin-bottom:3px;">PREPARED&nbsp;&nbsp;FOR</div>
      <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:22px;font-weight:600;color:#fff;"><%= clientName || 'Valued Client' %></div>
    </div>
    <div style="text-align:right;">
      <div style="font-size:10px;color:rgba(255,255,255,0.7);font-family:'Courier New','DM Mono',monospace;letter-spacing:1px;"><%= fmtDate(offerDate || new Date()) %></div>
    </div>
  </div>

  <!-- Center: Project Name + Details -->
  <div style="position:relative;z-index:1;flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:20px 48px;text-align:center;">
    <div style="font-size:10px;color:rgba(255,255,255,0.7);letter-spacing:5px;text-transform:uppercase;font-family:'Courier New','DM Mono',monospace;margin-bottom:16px;">EXCLUSIVE&nbsp;&nbsp;PROPERTY&nbsp;&nbsp;OFFER</div>
    <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:48px;font-weight:700;color:#fff;line-height:1.05;margin-bottom:12px;letter-spacing:-1px;"><%= project.name %></div>
    <div style="width:60px;height:2px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.6),transparent);margin-bottom:14px;"></div>
    <div style="font-size:14px;color:rgba(255,255,255,0.8);letter-spacing:1px;"><%= project.location %></div>
    <div style="margin-top:8px;display:flex;gap:16px;justify-content:center;">
      <span style="font-size:12px;color:rgba(255,255,255,0.75);"><%= project.type %></span>
      <span style="font-size:12px;color:rgba(255,255,255,0.4);">.</span>
      <span style="font-size:12px;color:rgba(255,255,255,0.75);"><%= project.status %></span>
      <span style="font-size:12px;color:rgba(255,255,255,0.4);">.</span>
      <span style="font-size:12px;color:<%= sc %>;font-weight:600;"><%= project.completionDate %></span>
    </div>
  </div>

  <!-- Unit Info Card -->
  <div style="position:relative;z-index:1;margin:0 48px 16px;border-radius:18px;overflow:hidden;border:1px solid rgba(255,255,255,0.16);background:rgba(255,255,255,0.12);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);box-shadow:0 16px 38px rgba(0,0,0,0.18);">
<% var hasFloor = project.type !== 'Townhouses';
      var gridCols = hasFloor ? 'repeat(7,1fr)' : 'repeat(6,1fr)'; %>
    <div style="display:grid;grid-template-columns:<%= gridCols %>;">
      <% var cols = [
        ['UNIT', String(unit.number)],
        ['TYPE', unitType ? unitType.label : '-'],
        ['SUBTYPE', unit.subtype || '-'],
        ['INTERNAL\nAREA', (unit.areaInternal || 0).toLocaleString() + ' sqft'],
        ['EXTERNAL\nAREA', (unit.areaExternal || 0).toLocaleString() + ' sqft'],
        ['TOTAL AREA', (unit.area || 0).toLocaleString() + ' sqft']
      ];
      if (hasFloor) cols.push(['FLOOR', String(unit.floor)]); %>
      <% cols.forEach(function(d, i) { %>
      <div style="padding:14px 16px;background:<%= i % 2 === 0 ? 'rgba(255,255,255,0.08)' : 'rgba(255,255,255,0.04)' %>;border-right:<%= i < cols.length - 1 ? '1px solid rgba(255,255,255,0.12)' : 'none' %>;text-align:center;">
        <div style="font-size:8px;color:rgba(255,255,255,0.6);letter-spacing:2px;text-transform:uppercase;font-family:'Courier New','DM Mono',monospace;margin-bottom:4px;white-space:pre-line;"><%= d[0] %></div>
        <div style="font-size:13px;font-weight:600;color:#fff;font-family:'Outfit','Segoe UI',Arial,sans-serif;"><%= d[1] %></div>
      </div>
      <% }); %>
    </div>
  </div>

  <!-- Footer: Agent + Prepared For -->
  <div style="position:relative;z-index:1;padding:14px 48px;background:rgba(0,0,0,0.22);border-top:1px solid rgba(255,255,255,0.16);display:flex;justify-content:space-between;align-items:center;">
    <div>
      <div style="font-size:9px;color:rgba(255,255,255,0.5);letter-spacing:3px;font-family:'Courier New','DM Mono',monospace;margin-bottom:3px;">PREPARED&nbsp;&nbsp;FOR</div>
      <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:18px;font-weight:600;color:#fff;"><%= clientName || 'Valued Client' %></div>
    </div>
    <div style="text-align:right;">
      <div style="font-size:12px;font-weight:600;color:#fff;"><%= agentName %></div>
      <div style="font-size:10px;color:rgba(255,255,255,0.7);margin-top:2px;"><%= settings.teamName || 'Reportage Properties' %></div>
    </div>
  </div>
</div>

<!-- Page 2: Investment + Offer Details -->
<div class="op" style="background:linear-gradient(180deg,#fcfaf7 0%,#f7efe6 100%);position:relative;overflow:hidden;">
  <% if (watermark || (settings && settings.teamName)) { %>
  <div style="position:absolute;top:40%;left:0;right:0;text-align:center;opacity:0.04;font-size:36px;font-weight:700;color:#1A2340;font-family:Georgia,'Cormorant Garamond',serif;letter-spacing:6px;transform:rotate(-30deg);pointer-events:none;z-index:0;">
    <% if (watermark && watermark.startsWith('data:')) { %>
    <img src="<%= watermark %>" alt="" style="width:160px;opacity:0.3;margin:0 auto;" />
    <% } else { %>
    <%= watermark || settings.teamName || '' %>
    <% } %>
  </div>
  <% } %>
  <div style="height:4px;background:linear-gradient(90deg,<%= pc %>,<%= sc %>,<%= pc %>);"></div>

  <!-- Why Buy bar -->
  <% if (project.whyBuy && project.whyBuy.length > 0) { %>
  <div style="padding:12px 48px;background:rgba(<%= hr %>,0.04);border-bottom:1px solid #e8ecf2;display:flex;gap:20px;flex-wrap:wrap;">
    <% project.whyBuy.forEach(function(pt) { %>
    <div style="display:flex;align-items:center;gap:6px;">
      <div style="width:5px;height:5px;border-radius:50%;background:<%= pc %>;flex-shrink:0;"></div>
      <span style="font-size:10px;color:#4A5880;"><%= pt %></span>
    </div>
    <% }); %>
  </div>
  <% } %>

  <!-- Investment Section -->
  <div style="padding:24px 48px 24px;">
    <div class="soft-card" style="padding:26px 30px 24px;border-radius:24px;display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start;">
      <!-- Left: Price -->
      <div>
        <div style="font-size:9px;color:#8892AA;letter-spacing:2.5px;text-transform:uppercase;font-family:'Courier New','DM Mono',monospace;margin-bottom:14px;">INVESTMENT</div>
        <% if (discountAmt > 0) {
          var listPrice = activeDiscount < 100 ? netPrice / (1 - activeDiscount / 100) : netPrice; %>
        <div style="font-size:14px;color:#8892AA;text-decoration:line-through;font-family:'Courier New','DM Mono',monospace;margin-bottom:4px;"><%= fmtAED(listPrice) %></div>
        <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(<%= hr %>,0.1);border:1px solid rgba(<%= hr %>,0.2);border-radius:20px;padding:4px 14px;margin-bottom:10px;">
          <div style="width:6px;height:6px;border-radius:50%;background:<%= pc %>;"></div>
          <span style="font-size:11px;color:<%= pc %>;font-weight:700;font-family:'Courier New','DM Mono',monospace;letter-spacing:1px;"><%= activeDiscount %>% DISCOUNT<%= eventName ? ' - ' + eventName : '' %></span>
        </div>
        <% } %>
        <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:42px;font-weight:700;color:<%= pc %>;line-height:1;margin-bottom:4px;letter-spacing:-1px;"><%= fmtAED(netPrice) %></div>
        <div style="font-size:11px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;margin-bottom:14px;">NET&nbsp;&nbsp;PRICE</div>
        <% if (hasPark) { %>
        <div style="margin-bottom:10px;">
          <div style="font-size:12px;color:#4A5880;margin-bottom:4px;">
            <% var bedMatch = (unitType && unitType.label || '').toLowerCase().match(/(\d+)\s*[b]/);
               var beds = bedMatch ? +bedMatch[1] : 1;
               var spaces = beds >= 3 ? 2 : 1; %>
            + Parking (<%= spaces %> space<%= spaces > 1 ? 's' : '' %>) = <%= fmtAED(parking) %>
          </div>
          <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:24px;font-weight:700;color:#1E6FD9;letter-spacing:-0.5px;"><%= fmtAED(priceWithPark) %></div>
          <div style="font-size:10px;color:#1E6FD9;font-family:'Courier New','DM Mono',monospace;">FINAL UNIT PRICE</div>
        </div>
        <% } %>
        <div style="padding:12px 14px;background:linear-gradient(135deg,rgba(123,63,26,0.06),rgba(212,168,138,0.14));border-radius:12px;border:1px solid rgba(123,63,26,0.12);display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;">
          <div>
            <div style="font-size:9px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;letter-spacing:1px;margin-bottom:2px;"><%= (project.feeLabel || 'REG FEE').toUpperCase() %></div>
            <div style="font-size:12px;font-weight:600;color:#1A2340;font-family:'Courier New','DM Mono',monospace;"><%= fmtAED(regFee) %></div>
          </div>
          <div>
            <div style="font-size:9px;color:#8892AA;font-family:'Courier New','DM Mono',monospace;letter-spacing:1px;margin-bottom:2px;">UTILITY</div>
            <div style="font-size:12px;font-weight:600;color:#1A2340;font-family:'Courier New','DM Mono',monospace;"><%= fmtAED(utility) %></div>
          </div>
        </div>
      </div>
      <!-- Right: Saving + Currency + Payment Structure -->
      <div>
        <% if (discountAmt > 0) { %>
        <div style="background:linear-gradient(135deg,rgba(39,174,96,0.08),rgba(39,174,96,0.04));border:1px solid rgba(39,174,96,0.2);border-radius:14px;padding:16px 20px;margin-bottom:14px;position:relative;overflow:hidden;box-shadow:0 10px 24px rgba(39,174,96,0.08);">
          <div style="position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:rgba(39,174,96,0.06);"></div>
          <div style="font-size:9px;color:#27AE60;letter-spacing:2.5px;text-transform:uppercase;font-family:'Courier New','DM Mono',monospace;margin-bottom:6px;">YOUR&nbsp;&nbsp;SAVING</div>
          <div style="font-family:Georgia,'Cormorant Garamond',serif;font-size:32px;font-weight:700;color:#27AE60;line-height:1;margin-bottom:4px;"><%= fmtAED(discountAmt) %></div>
          <div style="font-size:11px;color:rgba(39,174,96,0.7);"><%= activeDiscount %>% off list price of <%= fmtAED(activeDiscount < 100 ? netPrice / (1 - activeDiscount / 100) : netPrice) %></div>
        </div>
        <% } %>
        <div style="display:grid;grid-template-columns:<%= extraRate ? '1fr 1fr' : '1fr' %>;gap:10px;margin-bottom:14px;">
          <div style="padding:12px 14px;background:rgba(30,111,217,0.06);border-radius:12px;border:1px solid rgba(30,111,217,0.12);">
            <div style="font-size:9px;color:#8892AA;letter-spacing:1.5px;font-family:'Courier New','DM Mono',monospace;margin-bottom:4px;">USD</div>
            <div style="font-size:14px;font-weight:700;color:#1E6FD9;font-family:'Courier New','DM Mono',monospace;"><%= fmtUSD(priceWithPark, usdRate) %></div>
            <div style="font-size:9px;color:#8892AA;margin-top:2px;">1 USD = AED 3.65</div>
          </div>
          <% if (extraRate) { %>
          <div style="padding:12px 14px;background:rgba(<%= hr %>,0.06);border-radius:12px;border:1px solid rgba(<%= hr %>,0.12);">
            <div style="font-size:9px;color:#8892AA;letter-spacing:1.5px;font-family:'Courier New','DM Mono',monospace;margin-bottom:4px;"><%= extraCurrency %></div>
            <div style="font-size:14px;font-weight:700;color:#1A2340;font-family:'Courier New','DM Mono',monospace;"><%= (Math.round(priceWithPark * extraRate)).toLocaleString('en-US') %></div>
            <div style="font-size:9px;color:#8892AA;margin-top:2px;">1 AED = <%= extraCurrency %> <%= extraRate.toFixed(3) %></div>
          </div>
          <% } %>
        </div>
        <!-- Payment Structure -->
        <div>
          <div style="font-size:9px;color:#8892AA;letter-spacing:2.5px;text-transform:uppercase;font-family:'Courier New','DM Mono',monospace;margin-bottom:10px;">PAYMENT&nbsp;&nbsp;STRUCTURE</div>
          <div style="height:30px;border-radius:6px;overflow:hidden;display:flex;margin-bottom:8px;background:#F0F4FA;">
            <% segs.forEach(function(s) { %>
            <div style="flex:<%= s.pct %>;background:<%= s.color %>;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;min-width:<%= s.pct > 5 ? '20px' : '0' %>;"><%= s.pct > 8 ? s.pct + '%' : '' %></div>
            <% }); %>
          </div>
          <div style="display:flex;gap:14px;flex-wrap:wrap;font-size:11px;">
            <% segs.forEach(function(s) { %>
            <div style="display:flex;align-items:center;gap:6px;">
              <div style="width:10px;height:10px;border-radius:2px;background:<%= s.color %>;"></div>
              <span style="color:#4A5880;"><%= s.label %>: <strong><%= s.pct %>%</strong> = <%= fmtAED(Math.round((netPrice * s.pct) / 100)) %></span>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Payment Milestones (page 1 of the schedule — remaining rows, if any, continue on the next page[s]) -->
  <div style="padding:24px 48px;background:linear-gradient(180deg,#faf6f0 0%,#f2e8dc 100%);border-top:1px solid #eadfd7;">
    <div style="font-size:9px;color:#8892AA;letter-spacing:2.5px;text-transform:uppercase;font-family:'Courier New','DM Mono',monospace;margin-bottom:20px;">PAYMENT&nbsp;&nbsp;MILESTONES</div>
    <div style="position:relative;">
      <div style="position:absolute;left:22px;top:12px;bottom:12px;width:2px;background:linear-gradient(180deg,<%= pc %>,rgba(<%= hr %>,0.1));border-radius:1px;"></div>
      <div style="display:flex;flex-direction:column;gap:0;">
        <% msFirstChunk.forEach(function(m, i) {
          var dotColor = m.isHandover ? pc : m.isBooking ? '#C9A84C' : m.type === 'dp' ? pc : m.type === 'installment' ? '#0EA5A0' : pc;
          var dotSize = m.isHandover ? 16 : m.isBooking ? 14 : 10; %>
        <div style="display:flex;align-items:center;gap:16px;padding-bottom:<%= m.isHandover ? 0 : 6 %>px;position:relative;page-break-inside:avoid;">
          <div style="width:46px;display:flex;justify-content:center;flex-shrink:0;">
            <div style="width:<%= dotSize %>px;height:<%= dotSize %>px;border-radius:50%;background:<%= dotColor %>;border:2px solid #fff;box-shadow:0 0 0 2px <%= dotColor %>;flex-shrink:0;"></div>
          </div>
          <div style="flex:1;display:grid;grid-template-columns:1fr 44px 1fr;gap:0 12px;align-items:center;padding:<%= m.isHandover ? '10px 14px' : '5px 12px' %>;background:<%= m.isHandover ? 'rgba(' + hr + ',0.06)' : m.isBooking ? 'rgba(184,134,11,0.04)' : 'transparent' %>;border-radius:<%= m.isHandover ? 8 : 5 %>px;border:<%= m.isHandover ? '1px solid rgba(' + hr + ',0.12)' : 'none' %>;">
            <div>
              <div style="font-size:<%= m.isHandover ? 12 : 11 %>px;font-weight:<%= m.isHandover ? 700 : 500 %>;color:<%= m.isHandover ? pc : '#1A2340' %>;"><%= m.label %></div>
